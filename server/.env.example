# MongoDB connection string
# Local: mongodb://127.0.0.1:27017/internshipTracker
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/internshipTracker
MONGO_URI=mongodb://127.0.0.1:27017/internshipTracker

# Server port
PORT=8000

# JWT secret — use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret

# Frontend URL for CORS (default is Vite dev server)
CLIENT_URL=http://localhost:5173
